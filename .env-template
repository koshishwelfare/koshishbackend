# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/koshish

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=koshish
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Authentication Credentials
# Only Coordinator has default credentials
# Co-curricular, Teacher, and Student are onboarded dynamically and credentials are sent via email

COORDINATOR_USERNAME=coordinator@example.com
COORDINATOR_PASSWORD=coordinator123
COORDINATOR_NOTIFY_EMAIL=coordinator-notify@example.com

# CORS Configuration
CORS_ORIGIN=true

# Frontend URLs
STUDENT_FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174